# 预约抢票系统 - API 网关镜像
FROM golang:1.23-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/gateway ./apps/appointment/api

FROM alpine:3.19
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /app/gateway .
COPY apps/appointment/api/etc/appointment-api.yaml ./etc/
EXPOSE 8888
CMD ["./gateway", "-f", "etc/appointment-api.yaml"]
